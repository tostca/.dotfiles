{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "lsp": "allow"
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      // Or ["bun", "x", "my-mcp-command"]
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--isolated",
        "--executablePath",
        "/opt/google/chrome/chrome",
        "--no-usage-statistics"
      ],
      "enabled": true,
    },
    "polymarket_docs": {
      "type": "remote",
      "url": "https://docs.polymarket.com/mcp",
      "enabled": true
    },
    "uidotsh": {
      "type": "remote",
      "url": "https://ui.sh/mcp?agent=opencode",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:UIDOTSH_TOKEN}"
      }
    },
    "stitch": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true,
      "headers": {
        "X-Goog-Api-Key": "{env:STITCH_TOKEN}"
      }
    },
  },
  "plugin": [
    "superpowers-ruby@git+https://github.com/lucianghinda/superpowers-ruby.git"
  ]
}
